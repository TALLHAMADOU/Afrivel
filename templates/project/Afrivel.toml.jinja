# Manifeste Afrivel — source de vérité pour la composition du projet.
# Édité par la CLI (`afrivel make:module`). `app/Cargo.toml`, `app/src/registry.rs`
# et `app/src/migrator.rs` en sont régénérés.
[project]
name = "{{ name }}"
afrivel_version = "{{ afrivel_version }}"

# Un bloc [modules.<nom>] par module enregistré.
[modules]
